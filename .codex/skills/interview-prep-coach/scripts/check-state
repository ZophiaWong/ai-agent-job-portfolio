#!/usr/bin/env python3
import argparse
from pathlib import Path

STATE_REL = Path('.local') / 'interview-prep'
REQUIRED_FILES = ['goal.md', 'plan.md', 'weaknesses.md', 'resume.md', 'projects.md']
OPTIONAL_FILES = ['jd.md']
REQUIRED_DIRS = ['sessions/mock', 'sessions/learn', 'sessions/review']


def parse_args():
    parser = argparse.ArgumentParser(description='Check private interview prep state files.')
    parser.add_argument('--root', default='.', help='Repository root. Defaults to current directory.')
    return parser.parse_args()


def main():
    args = parse_args()
    root = Path(args.root).resolve()
    state_dir = root / STATE_REL
    missing_required = []
    missing_optional = []

    for name in REQUIRED_FILES:
        if not (state_dir / name).is_file():
            missing_required.append(str(STATE_REL / name))
    for name in OPTIONAL_FILES:
        if not (state_dir / name).is_file():
            missing_optional.append(str(STATE_REL / name))
    for name in REQUIRED_DIRS:
        if not (state_dir / name).is_dir():
            missing_required.append(str(STATE_REL / name) + '/')

    if missing_required:
        print('Missing required interview prep state:')
        for item in missing_required:
            print(f'- {item}')
        print('Run scripts/init-interview-prep --root <repo> to create templates.')
        return 1

    print('Interview prep state ready.')
    if missing_optional:
        print('Optional missing:')
        for item in missing_optional:
            print(f'- {item}')
    else:
        print('Optional personalization files present.')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
