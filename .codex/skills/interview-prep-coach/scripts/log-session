#!/usr/bin/env python3
import argparse
import json
import re
import sys
from datetime import datetime
from pathlib import Path

from state_utils import (
    ensure_within_boundary,
    state_dir_for,
    validate_competency_id,
    validate_single_line,
    write_exclusive_with_suffix,
)


EVIDENCE_SESSION_TYPES = {'diagnostic', 'learn', 'mock'}
ASSESSMENT_DIMENSIONS = (
    'correctness',
    'completeness',
    'depth',
    'application',
    'tradeoffs',
    'project_truth',
    'communication',
    'follow_up_resilience',
    'epistemic_safety',
)
COMPLETION_SECTIONS = (
    'Questions and answers',
    'Evidence excerpts',
    'Evaluator',
    'Critic',
    'Project evidence',
    'Proposed state changes',
    'Approval',
)


def slugify(value):
    slug = re.sub(r'[^a-zA-Z0-9]+', '-', value.strip().lower()).strip('-')
    return slug[:60] or 'session'


def parse_args():
    parser = argparse.ArgumentParser(description='Append an interview prep session log entry.')
    parser.add_argument('--root', default='.', help='Repository root. Defaults to current directory.')
    parser.add_argument(
        '--type',
        choices=['diagnostic', 'mock', 'learn', 'review'],
        required=True,
        help='Session type.',
    )
    parser.add_argument('--title', help='Session title. Required for a new session.')
    parser.add_argument(
        '--session-id',
        help='Existing session file stem to resume. The file must already exist.',
    )
    parser.add_argument(
        '--status',
        choices=['in-progress', 'completed', 'abandoned'],
        help='New sessions default to in-progress; a resumed session keeps its current status.',
    )
    parser.add_argument('--primary-competency', help='Stable competency ID, for example C05.04.')
    parser.add_argument(
        '--covered-topic',
        action='append',
        default=[],
        help='Taught or tested topic; repeat the option to record multiple topics.',
    )
    parser.add_argument(
        '--related-topic',
        action='append',
        default=[],
        help='Mentioned but untested topic; repeat the option to record multiple topics.',
    )
    parser.add_argument('--content', help='Entry content. Reads all stdin when omitted.')
    args = parser.parse_args()
    if args.session_id is None and not args.title:
        parser.error('--title is required when creating a new session')
    return args


def validate_session_id(value):
    if not re.fullmatch(r'[a-z0-9][a-z0-9-]{0,119}', value):
        raise ValueError('session ID must contain only lowercase letters, digits, and hyphens')


def update_status(path, status):
    text = path.read_text(encoding='utf-8')
    updated, count = re.subn(
        r'^- Status: .+$',
        f'- Status: {status}',
        text,
        count=1,
        flags=re.MULTILINE,
    )
    if count != 1:
        raise ValueError(f'missing status metadata in {path}')
    path.write_text(updated, encoding='utf-8')


def read_primary_competency(path):
    text = path.read_text(encoding='utf-8')
    match = re.search(r'^- Primary competency: (.+)$', text, flags=re.MULTILINE)
    if match is None:
        raise ValueError(f'missing primary competency metadata in {path}')
    value = match.group(1)
    if value != 'not-set':
        validate_competency_id(value)
    return value


def read_status(path):
    text = path.read_text(encoding='utf-8')
    match = re.search(r'^- Status: (in-progress|completed|abandoned)$', text, flags=re.MULTILINE)
    if match is None:
        raise ValueError(f'missing or invalid status metadata in {path}')
    return match.group(1)


def update_primary_competency(path, competency):
    text = path.read_text(encoding='utf-8')
    updated, count = re.subn(
        r'^- Primary competency: .+$',
        f'- Primary competency: {competency}',
        text,
        count=1,
        flags=re.MULTILINE,
    )
    if count != 1:
        raise ValueError(f'missing primary competency metadata in {path}')
    path.write_text(updated, encoding='utf-8')


def parse_topic_metadata(text, label):
    match = re.search(rf'^- {re.escape(label)}: (.*)$', text, flags=re.MULTILINE)
    if match is None:
        raise ValueError(f'missing {label.lower()} metadata')
    raw = match.group(1)
    if raw == 'not-set':
        return []
    if not raw.startswith('['):
        return [raw]
    try:
        values = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise ValueError(f'invalid {label.lower()} metadata') from exc
    if not isinstance(values, list) or not all(isinstance(value, str) for value in values):
        raise ValueError(f'invalid {label.lower()} metadata')
    return values


def merge_topic_metadata(path, covered_topics, related_topics):
    text = path.read_text(encoding='utf-8')
    for label, additions in (
        ('Covered topics', covered_topics),
        ('Related topics', related_topics),
    ):
        if not additions:
            continue
        existing = parse_topic_metadata(text, label)
        merged = list(dict.fromkeys([*existing, *additions]))
        replacement = f'- {label}: {json.dumps(merged, ensure_ascii=False)}'
        text, count = re.subn(
            rf'^- {re.escape(label)}: .*$',
            lambda _match: replacement,
            text,
            count=1,
            flags=re.MULTILINE,
        )
        if count != 1:
            raise ValueError(f'missing {label.lower()} metadata in {path}')
    path.write_text(text, encoding='utf-8')


def build_entry(now, content):
    return f"\n## Entry {now:%H:%M:%S}\n\n{content.rstrip()}\n"


def section_body(text, heading):
    match = re.search(
        rf'^## {re.escape(heading)}\s*$\n(?P<body>.*?)(?=^## |\Z)',
        text,
        flags=re.MULTILINE | re.DOTALL,
    )
    if match is None:
        return None
    return match.group('body').strip()


def require_field(issues, body, label, value_pattern=r'.+', issue_label=None):
    if re.search(
        rf'^\s*- {re.escape(label)}:\s+{value_pattern}\s*$',
        body,
        flags=re.MULTILINE,
    ) is None:
        issues.append(issue_label or label)


def field_value(body, label):
    match = re.search(
        rf'^\s*- {re.escape(label)}:\s+(?P<value>\S.*)$',
        body,
        flags=re.MULTILINE,
    )
    if match is None:
        return None
    return match.group('value').strip()


def validate_completion_contract(text):
    sections = {heading: section_body(text, heading) for heading in COMPLETION_SECTIONS}
    issues = [heading for heading, body in sections.items() if not body]

    questions = sections['Questions and answers'] or ''
    require_field(issues, questions, 'Question')
    require_field(issues, questions, 'Answer')

    excerpts = sections['Evidence excerpts'] or ''
    if re.search(r'^-\s+\S', excerpts, flags=re.MULTILINE) is None:
        issues.append('Evidence excerpt')

    evaluator = sections['Evaluator'] or ''
    require_field(issues, evaluator, 'Question type')
    for dimension in ASSESSMENT_DIMENSIONS:
        require_field(
            issues,
            evaluator,
            dimension,
            r'(?:[0-4]|not-applicable)\s+(?:-|—)\s+.+',
        )
    require_field(issues, evaluator, 'Highest hint level', r'[0-4]')
    require_field(
        issues,
        evaluator,
        'Evidence state',
        r'(?:introduced|assisted|independent|transfer-passed|retained)',
    )
    require_field(issues, evaluator, 'Follow-up / transfer result')
    require_field(issues, evaluator, 'Satisfied gate')
    require_field(issues, evaluator, 'Applied caps')
    require_field(issues, evaluator, 'Rubric version', r'interview-prep-v1')
    require_field(issues, evaluator, 'Judge mode')
    require_field(issues, evaluator, 'Assessment time')
    require_field(issues, evaluator, 'Confidence', r'(?:low|medium|high)')
    require_field(issues, evaluator, 'Next validation')
    require_field(issues, evaluator, 'Errors')
    require_field(issues, evaluator, 'Omissions')
    require_field(issues, evaluator, 'Communication issues')

    critic = sections['Critic'] or ''
    require_field(issues, critic, 'Critic result', r'(?:pass|follow-up-required)')

    project_evidence = sections['Project evidence'] or ''
    project_claims = list(
        re.finditer(
            r'^- Claim:\s+\S.*?$(?P<details>.*?)(?=^- Claim:|\Z)',
            project_evidence,
            flags=re.MULTILINE | re.DOTALL,
        )
    )
    if not project_claims:
        issues.append('Project claim')
    for index, claim in enumerate(project_claims, start=1):
        details = claim.group('details')
        require_field(
            issues,
            details,
            'Source snapshot',
            issue_label=f'Project claim {index} Source snapshot',
        )
        require_field(
            issues,
            details,
            'Truth category',
            r'(?:implemented|planned|proposed|unknown|not-applicable)',
            issue_label=f'Project claim {index} Truth category',
        )

    proposed_changes = sections['Proposed state changes'] or ''
    require_field(issues, proposed_changes, 'Matrix')
    require_field(issues, proposed_changes, 'Weaknesses')
    require_field(issues, proposed_changes, 'Plan')

    approval = sections['Approval'] or ''
    require_field(
        issues,
        approval,
        'Approval decision',
        r'(?:approved|rejected|partial)',
    )

    confidence = field_value(evaluator, 'Confidence')
    critic_result = field_value(critic, 'Critic result')
    epistemic_safety = field_value(evaluator, 'epistemic_safety')
    matrix_change = field_value(proposed_changes, 'Matrix')
    unsafe_epistemics = (
        epistemic_safety is not None
        and epistemic_safety.split(maxsplit=1)[0] in {'0', '1'}
    )
    if (
        matrix_change is not None
        and (confidence == 'low' or critic_result == 'follow-up-required' or unsafe_epistemics)
        and matrix_change.lower() != 'no change'
    ):
        issues.append(
            'Matrix must be no change when confidence is low, the Critic requires '
            'follow-up, or epistemic_safety is 0-1'
        )

    if issues:
        unique_issues = list(dict.fromkeys(issues))
        raise ValueError(
            'Completion contract is incomplete or invalid; missing/invalid: '
            + ', '.join(unique_issues)
        )


def main():
    args = parse_args()
    root = Path(args.root).resolve()
    try:
        state_dir = state_dir_for(root)
        session_dir = ensure_within_boundary(
            state_dir / 'sessions' / args.type,
            state_dir,
            root,
            f'{args.type} session directory',
        )
        if args.title is not None:
            validate_single_line(args.title, 'title')
        if args.primary_competency is not None:
            validate_competency_id(args.primary_competency)
        for topic in args.covered_topic:
            validate_single_line(topic, 'covered topic')
        for topic in args.related_topic:
            validate_single_line(topic, 'related topic')
    except ValueError as exc:
        raise SystemExit(str(exc)) from exc
    session_dir.mkdir(parents=True, exist_ok=True)

    now = datetime.now().astimezone()
    content = args.content if args.content is not None else sys.stdin.read()
    entry = build_entry(now, content)
    resumed_status = None

    if args.session_id is not None:
        try:
            validate_session_id(args.session_id)
        except ValueError as exc:
            raise SystemExit(str(exc)) from exc
        try:
            path = ensure_within_boundary(
                session_dir / f'{args.session_id}.md',
                session_dir,
                root,
                'session file',
            )
        except ValueError as exc:
            raise SystemExit(str(exc)) from exc
        if not path.is_file():
            raise SystemExit(f'session does not exist: {path}')
        try:
            current_status = read_status(path)
            if current_status != 'in-progress':
                raise ValueError(
                    f'terminal session is immutable ({current_status}); create a new session'
                )
            existing_primary = read_primary_competency(path)
            if args.primary_competency is not None:
                if existing_primary == 'not-set':
                    existing_primary = args.primary_competency
                elif existing_primary != args.primary_competency:
                    raise ValueError(
                        'primary competency cannot change when resuming a session'
                    )
            if (
                args.type in EVIDENCE_SESSION_TYPES
                and args.status == 'completed'
                and existing_primary == 'not-set'
            ):
                raise ValueError(
                    '--primary-competency is required before completing this session'
                )
            if args.type in EVIDENCE_SESSION_TYPES and args.status == 'completed':
                validate_completion_contract(path.read_text(encoding='utf-8') + entry)
            if args.primary_competency is not None and read_primary_competency(path) == 'not-set':
                update_primary_competency(path, args.primary_competency)
            if args.covered_topic or args.related_topic:
                merge_topic_metadata(path, args.covered_topic, args.related_topic)
            resumed_status = args.status
        except ValueError as exc:
            raise SystemExit(str(exc)) from exc
    else:
        if args.type in EVIDENCE_SESSION_TYPES and args.primary_competency is None:
            raise SystemExit(
                '--primary-competency is required for diagnostic, learn, and mock sessions'
            )
        status = args.status or 'in-progress'
        base_session_id = f'{args.type}-{now:%Y%m%d-%H%M%S-%f}-{slugify(args.title)}'
        covered_topics = json.dumps(
            list(dict.fromkeys(args.covered_topic)), ensure_ascii=False
        )
        related_topics = json.dumps(
            list(dict.fromkeys(args.related_topic)), ensure_ascii=False
        )

        def build_header(session_id):
            return (
                f"# {args.title}\n\n"
                f"- Session ID: {session_id}\n"
                f"- Type: {args.type}\n"
                f"- Status: {status}\n"
                f"- Started at: {now.isoformat(timespec='seconds')}\n"
                f"- Primary competency: {args.primary_competency or 'not-set'}\n"
                f"- Covered topics: {covered_topics}\n"
                f"- Related topics: {related_topics}\n\n"
            )

        if args.type in EVIDENCE_SESSION_TYPES and status == 'completed':
            try:
                validate_completion_contract(build_header(base_session_id) + entry)
            except ValueError as exc:
                raise SystemExit(str(exc)) from exc

        try:
            path, _ = write_exclusive_with_suffix(
                session_dir, base_session_id, build_header, root
            )
        except (RuntimeError, ValueError) as exc:
            raise SystemExit(str(exc)) from exc

    with path.open('a', encoding='utf-8') as handle:
        handle.write(entry)

    if resumed_status is not None:
        try:
            update_status(path, resumed_status)
        except ValueError as exc:
            raise SystemExit(str(exc)) from exc

    print(path)
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
