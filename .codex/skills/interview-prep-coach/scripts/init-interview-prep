#!/usr/bin/env python3
import argparse
import shutil
from pathlib import Path

from state_utils import STATE_REL, ensure_within_boundary, state_dir_for


TEMPLATE_FILES = [
    'goal.md',
    'plan.md',
    'weaknesses.md',
    'resume.md',
    'projects.md',
    'competency-matrix.md',
    'daily.md',
    'introduction.md',
    'stories.md',
    'jd.md',
]
SESSION_DIRS = ['diagnostic', 'mock', 'learn', 'review']


def parse_args():
    parser = argparse.ArgumentParser(description='Initialize private interview prep state files.')
    parser.add_argument('--root', default='.', help='Repository root. Defaults to current directory.')
    return parser.parse_args()


def main():
    args = parse_args()
    root = Path(args.root).resolve()
    try:
        state_dir = state_dir_for(root)
    except ValueError as exc:
        raise SystemExit(str(exc)) from exc
    templates_dir = Path(__file__).resolve().parents[1] / 'assets' / 'templates'
    created = []
    preserved = []

    state_dir.mkdir(parents=True, exist_ok=True)
    for name in TEMPLATE_FILES:
        try:
            target = ensure_within_boundary(
                state_dir / name, state_dir, root, f'state file {name}'
            )
        except ValueError as exc:
            raise SystemExit(str(exc)) from exc
        source = templates_dir / name
        if target.exists():
            preserved.append(str(target.relative_to(root)))
            continue
        shutil.copyfile(source, target)
        created.append(str(target.relative_to(root)))

    for session_type in SESSION_DIRS:
        try:
            session_dir = ensure_within_boundary(
                state_dir / 'sessions' / session_type,
                state_dir,
                root,
                f'{session_type} session directory',
            )
        except ValueError as exc:
            raise SystemExit(str(exc)) from exc
        if session_dir.exists():
            preserved.append(str(session_dir.relative_to(root)) + '/')
        else:
            session_dir.mkdir(parents=True)
            created.append(str(session_dir.relative_to(root)) + '/')

    print('Interview prep state initialized.')
    if created:
        print('Created:')
        for item in created:
            print(f'- {item}')
    if preserved:
        print('Preserved:')
        for item in preserved:
            print(f'- {item}')
    print(
        'Fill in goal.md, resume.md, and projects.md before diagnostic or mock '
        'sessions. jd.md is optional.'
    )
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
