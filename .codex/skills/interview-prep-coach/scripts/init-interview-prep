#!/usr/bin/env python3
import argparse
import shutil
from pathlib import Path

STATE_REL = Path('.local') / 'interview-prep'
TEMPLATE_FILES = ['goal.md', 'plan.md', 'weaknesses.md', 'resume.md', 'projects.md', 'jd.md']
SESSION_DIRS = ['mock', 'learn', 'review']


def parse_args():
    parser = argparse.ArgumentParser(description='Initialize private interview prep state files.')
    parser.add_argument('--root', default='.', help='Repository root. Defaults to current directory.')
    return parser.parse_args()


def main():
    args = parse_args()
    root = Path(args.root).resolve()
    state_dir = root / STATE_REL
    templates_dir = Path(__file__).resolve().parents[1] / 'assets' / 'templates'
    created = []
    preserved = []

    state_dir.mkdir(parents=True, exist_ok=True)
    for name in TEMPLATE_FILES:
        target = state_dir / name
        source = templates_dir / name
        if target.exists():
            preserved.append(str(target.relative_to(root)))
            continue
        shutil.copyfile(source, target)
        created.append(str(target.relative_to(root)))

    for session_type in SESSION_DIRS:
        session_dir = state_dir / 'sessions' / session_type
        if session_dir.exists():
            preserved.append(str(session_dir.relative_to(root)) + '/')
        else:
            session_dir.mkdir(parents=True)
            created.append(str(session_dir.relative_to(root)) + '/')

    print('Interview prep state initialized.')
    if created:
        print('Created:')
        for item in created:
            print(f'- {item}')
    if preserved:
        print('Preserved:')
        for item in preserved:
            print(f'- {item}')
    print('Fill in goal.md, resume.md, and projects.md before mock sessions. jd.md is optional.')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
