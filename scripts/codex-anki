#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

exec codex -C "$PWD" \
  -c 'mcp_servers.anki-mcp.command="npx"' \
  -c 'mcp_servers.anki-mcp.args=["-y","@ankimcp/anki-mcp-server","--stdio"]' \
  -c 'mcp_servers.anki-mcp.startup_timeout_sec=120' \
  -c 'mcp_servers.anki-mcp.env.ANKI_CONNECT_URL="http://localhost:8765"' \
  -c 'mcp_servers.anki-mcp.env.NO_PROXY="localhost,127.0.0.1,::1"' \
  -c 'mcp_servers.anki-mcp.env.no_proxy="localhost,127.0.0.1,::1"' \
  "$@"
